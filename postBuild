#!/usr/bin/env bash
set -euo pipefail

# Install the .NET Interactive (Polyglot) Jupyter kernel so users can compile
# and run C# in notebook cells. The `dotnet` SDK itself comes from
# environment.yml (conda-forge dotnet-sdk). https://github.com/dotnet/interactive
#
# The tool and kernelspec must live in baked image locations rather than the
# user's home directory (~/.dotnet, ~/.local/share/jupyter), which is masked by
# a persistent volume at runtime on the hub.
export DOTNET_CLI_TELEMETRY_OPTOUT=1
export DOTNET_NOLOGO=1
export DOTNET_SKIP_FIRST_TIME_EXPERIENCE=1
DOTNET_TOOLS=${NB_PYTHON_PREFIX}/dotnet-tools
# Tool version targets net10.0; keep its major in sync with dotnet-sdk above.
dotnet tool install Microsoft.dotnet-interactive \
  --version 1.0.712001 \
  --tool-path "${DOTNET_TOOLS}"
"${DOTNET_TOOLS}/dotnet-interactive" jupyter install \
  --path "${NB_PYTHON_PREFIX}/share/jupyter/kernels"

# installing chromium browser to enable webpdf conversion using nbconvert
export PLAYWRIGHT_BROWSERS_PATH=${CONDA_DIR}
playwright install chromium

# https://github.com/berkeley-dsep-infra/datahub/issues/5827
git config --system pull.rebase false

# overrides.json is a file that jupyterlab reads to determine some settings
# 1) remove the 'create shareable link' option from the filebrowser context menu
mkdir -p ${NB_PYTHON_PREFIX}/share/jupyter/lab/settings
cp -p overrides.json ${NB_PYTHON_PREFIX}/share/jupyter/lab/settings

# code-server's conda package assets are installed in share/code-server.
export VSCODE_EXTENSIONS=${CONDA_DIR}/envs/notebook/share/code-server/extensions
mkdir -p ${VSCODE_EXTENSIONS}

# This is not reproducible, and it can be difficult to version these.
for x in \
  ms-dotnettools.vscode-dotnet-runtime \
  jakubkozera.csharp-dev-tools \
  ; do
    code-server --extensions-dir ${VSCODE_EXTENSIONS} --install-extension $x
done
